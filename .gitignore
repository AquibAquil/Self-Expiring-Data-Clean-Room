# Hive / commit log storage (per-agent temp dirs are already in systemTemp; this is a safety net)
**/storage/
**/commit_log/

# Atsign credentials — NEVER commit
*.atKeys
.atsign/

# Compiled CLI binaries (recompile locally instead of shipping a Windows-only binary)
agents/*.exe
agents/linux/

# Test data (regenerate via scripts/generate_data.dart)
ids_a.txt
ids_b.txt

# Shared salt for the hash — must be distributed out-of-band, never committed
salt.bin
*.salt
